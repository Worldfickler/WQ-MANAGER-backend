# Environment variables
PROJECT_NAME=WQ Manager API
VERSION=1.0.0
API_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS (comma separated)
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database Configuration
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306
DEBUG=True

# Logging Configuration
LOG_LEVEL=INFO
SQL_ECHO=True
SQL_ECHO_POOL=False
LOG_DIR=logs

# Redis Cache
REDIS_URL=redis://:password@127.0.0.1:6379/0
CACHE_EXPIRE_HOUR=13
CACHE_EXPIRE_MINUTE=0
CACHE_TIMEZONE=Asia/Shanghai

# MinIO Object Storage
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=wqmanager
MINIO_SECURE=False
# Optional public base url for object access
MINIO_PUBLIC_BASE_URL=http://your-minio-host:9000